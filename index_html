<!DOCTYPE html>
<html lang="es">
<head>
<link rel="icon" type="image/jpeg" href="imagenes/foto.jpg">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Valera Sport | Tienda Oficial</title>

    <!-- Cargamos Tailwind CSS para diseño rápido y elegante -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Google Fonts deportivas -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- FontAwesome para iconos de redes y deporte -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #000000; /* Negro absoluto OLED de alta gama */
            scroll-behavior: smooth;
        }
        h1, h2, h3, .font-brand {
            font-family: 'Outfit', sans-serif;
        }
        /* Desvanecido sutil para transiciones del modal */
        .modal-transition {
            transition: opacity 0.3s ease, transform 0.3s ease;
        }
        /* Efecto de "toque" reutilizable: ícono discreto que reacciona al hover/touch */
        .icon-touch {
            transition: transform 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease, color 0.18s ease;
        }
        .icon-touch:hover, .icon-touch:active {
            transform: scale(1.08);
        }
        .icon-touch:active {
            transform: scale(0.94);
        }
        /* Scrollbar discreto (opcional, mejora estética en escritorio) */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #000; }
        ::-webkit-scrollbar-thumb { background: #27272a; border-radius: 4px; }

        /* Estado vacío del buscador */
        #sinResultados { display: none; }

        /* Sello de agotado (nuevo) */
        .sello-agotado {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: #7f1d1d;
            color: #fca5a5;
            font-size: 11px;
            font-weight: 800;
            padding: 4px 10px;
            border-radius: 999px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .tarjeta-agotada { opacity: 0.55; }
        .boton-deshabilitado {
            pointer-events: none;
            opacity: 0.5;
        }
        #estadoCarga {
            text-align: center;
            color: #71717a;
            font-size: 13px;
            margin-bottom: 24px;
        }
    </style>
</head>
<body class="text-slate-300 antialiased min-h-screen flex flex-col justify-between">

    <!-- BARRA DE NAVEGACIÓN -->
    <header class="sticky top-0 z-50 bg-black/80 backdrop-blur-md border-b border-zinc-900">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">

            <!-- Logo de la Marca -->
            <a href="#" class="flex items-center gap-2">
                <span class="text-2xl font-black tracking-wider text-white">VALERA<span class="text-cyan-500">SPORT</span></span>
            </a>

            <!-- Enlaces rápidos -->
            <nav class="hidden md:flex items-center gap-8 text-sm font-medium">
                <a href="#productos" class="text-slate-400 hover:text-white transition">Catálogo</a>
                <a href="#categorias" class="text-slate-400 hover:text-white transition">Categorías</a>
                <a href="#contacto" class="text-slate-400 hover:text-cyan-400 transition">Ubicación</a>
            </nav>

            <!-- Botón de Contacto Directo General (ícono más discreto) -->
            <div>
                <a href="https://wa.me/584245939407?text=Hola%20Valera%20Sport,%20estoy%20viendo%20su%20p%C3%A1gina%20web%20y%20quiero%20m%C3%A1s%20informaci%C3%B3n" target="_blank" class="icon-touch bg-cyan-500 hover:bg-cyan-400 text-gray-950 font-bold px-4 py-2 rounded-full text-xs tracking-wider uppercase transition flex items-center gap-1.5 shadow-md shadow-cyan-500/10">
                    <i class="fa-brands fa-whatsapp text-sm"></i> Consultar
                </a>
            </div>
        </div>
    </header>

    <!-- SECCIÓN HERO (BANNER PRINCIPAL) -->
    <section class="relative overflow-hidden bg-black py-16 lg:py-24">
        <!-- Efectos de Luces de Fondo (Glows de Apple) -->
        <div class="absolute -top-10 -right-10 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-96 h-96 bg-purple-500/5 rounded-full blur-3xl pointer-events-none"></div>

        <div class="max-w-4xl mx-auto px-6 flex flex-col items-center text-center space-y-6">

           
            <h1 class="text-4xl lg:text-5xl font-black text-white leading-tight uppercase">
                Rendimiento Sin Límites
            </h1>
            <p class="text-base lg:text-lg text-slate-400 max-w-xl">
                Descubre la ropa deportiva más resistente y cómoda de Barquisimeto. Chaquetas rompevientos, conjuntos para damas y bóxers premium diseñados para dar tu 100% todos los días.
            </p>
            <div class="pt-2">
                <a href="#productos" class="inline-block bg-gradient-to-r from-cyan-500 to-purple-500 hover:from-cyan-400 hover:to-purple-400 text-white font-extrabold px-8 py-4 rounded-xl text-sm tracking-wider uppercase shadow-lg shadow-cyan-500/20 transition">
                    Ver Catálogo de Ropa
                </a>
            </div>
        </div>
    </section>

    <!-- GRILLA DE CATEGORÍAS (clicables, filtran el catálogo) -->
    <section id="categorias" class="py-16 bg-black border-y border-zinc-900">
        <div class="max-w-7xl mx-auto px-6">
            <h2 class="text-3xl font-black text-white uppercase tracking-tight mb-10 text-center lg:text-left">Explorar Categorías</h2>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Caballeros (Brillo Cyan) -->
                <div onclick="filtrarPorCategoria('Caballeros')" class="bg-zinc-950 border border-zinc-900/80 rounded-2xl p-8 hover:border-cyan-500/60 hover:shadow-[0_0_35px_rgba(6,182,212,0.14)] hover:-translate-y-1 transition-all duration-300 group cursor-pointer">
                    <div class="icon-touch w-10 h-10 bg-cyan-950/50 border border-cyan-800/30 rounded-xl flex items-center justify-center text-cyan-400 mb-6 group-hover:bg-cyan-500 group-hover:text-gray-950 group-hover:shadow-[0_0_12px_rgba(6,182,212,0.35)]">
                        <i class="fa-solid fa-shirt text-base"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-2">Caballeros</h3>
                    <p class="text-sm text-slate-400">Chaquetas térmicas, camisas dry-fit y bóxers premium para comodidad máxima.</p>
                </div>

                <!-- Damas (Brillo Morado) -->
                <div onclick="filtrarPorCategoria('Damas')" class="bg-zinc-950 border border-zinc-900/80 rounded-2xl p-8 hover:border-purple-500/60 hover:shadow-[0_0_35px_rgba(168,85,247,0.14)] hover:-translate-y-1 transition-all duration-300 group cursor-pointer">
                    <div class="icon-touch w-10 h-10 bg-purple-950/50 border border-purple-800/30 rounded-xl flex items-center justify-center text-purple-400 mb-6 group-hover:bg-purple-500 group-hover:text-white group-hover:shadow-[0_0_12px_rgba(168,85,247,0.35)]">
                        <i class="fa-solid fa-vest-patches text-base"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-2">Damas</h3>
                    <p class="text-sm text-slate-400">Licras de compresión, conjuntos deportivos de alta resistencia y tops de entrenamiento.</p>
                </div>

                <!-- Combos (Brillo Verde) -->
                <div onclick="filtrarPorCategoria('Combos')" class="bg-zinc-950 border border-zinc-900/80 rounded-2xl p-8 hover:border-emerald-500/60 hover:shadow-[0_0_35px_rgba(16,185,129,0.14)] hover:-translate-y-1 transition-all duration-300 group cursor-pointer">
                    <div class="icon-touch w-10 h-10 bg-emerald-950/50 border border-emerald-800/30 rounded-xl flex items-center justify-center text-emerald-400 mb-6 group-hover:bg-emerald-500 group-hover:text-gray-950 group-hover:shadow-[0_0_12px_rgba(16,185,129,0.35)]">
                        <i class="fa-solid fa-tags text-base"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-2">Combos Deportivos</h3>
                    <p class="text-sm text-slate-400">Ahorra comprando en paquetes. Oferta al mayor para revendedores.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- SECCIÓN PRODUCTOS -->
    <section id="productos" class="py-20 max-w-7xl mx-auto px-6 w-full">
        <div class="text-center max-w-2xl mx-auto mb-10">
            <h2 class="text-4xl font-black text-white uppercase tracking-tight">Prendas Destacadas</h2>
            <p class="text-slate-400 mt-4">Haz clic en ordenar para elegir tu talla e iniciar tu compra directa por WhatsApp.</p>
        </div>

        <!-- BUSCADOR -->
        <div class="max-w-xl mx-auto mb-4">
            <div class="relative">
                <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 text-sm pointer-events-none"></i>
                <input
                    type="text"
                    id="buscador"
                    oninput="reiniciarYRenderizar()"
                    placeholder="Buscar por nombre, categoría o descripción..."
                    class="w-full bg-zinc-950 border border-zinc-900 focus:border-cyan-500/50 rounded-full pl-11 pr-11 py-3 text-sm text-white placeholder:text-slate-600 outline-none transition focus:shadow-[0_0_0_3px_rgba(6,182,212,0.12)]"
                >
                <button
                    id="btnLimpiar"
                    onclick="limpiarBusqueda()"
                    class="icon-touch absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 hover:text-white w-6 h-6 flex items-center justify-center rounded-full hidden">
                    <i class="fa-solid fa-xmark text-xs"></i>
                </button>
            </div>

            <!-- Chip de categoría activa -->
            <div id="chipCategoria" class="hidden mt-3 flex items-center justify-center gap-2 text-xs text-slate-400">
                <span>Filtrando por:</span>
                <span id="chipCategoriaTexto" class="bg-zinc-900 border border-zinc-800 text-white px-3 py-1 rounded-full font-semibold"></span>
                <button onclick="filtrarPorCategoria(null)" class="icon-touch text-slate-500 hover:text-white w-5 h-5 flex items-center justify-center rounded-full">
                    <i class="fa-solid fa-xmark text-xs"></i>
                </button>
            </div>
        </div>

        <!-- Estado de carga del Sheet (nuevo) -->
        <p id="estadoCarga">Cargando catálogo...</p>

        <!-- Contador de resultados -->
        <p id="contadorResultados" class="text-center text-xs text-slate-600 uppercase tracking-wider mb-10"></p>

        <!-- Grid de productos (se llena por JavaScript) -->
        <div id="gridProductos" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"></div>

        <!-- BOTÓN BUSCAR MAS (Muestra de 5 en 5 de forma limpia) -->
        <div class="text-center mt-12" id="containerVerMas">
            <button onclick="cargarMasProductos()" class="icon-touch bg-zinc-950 border border-zinc-900 hover:border-zinc-700 text-slate-400 hover:text-white font-extrabold px-8 py-4 rounded-xl text-sm tracking-wider uppercase transition">
                Buscar más prendas <i class="fa-solid fa-chevron-down ml-1.5 text-xs"></i>
            </button>
        </div>

        <!-- Estado vacío -->
        <div id="sinResultados" class="text-center py-20">
            <div class="w-14 h-14 mx-auto rounded-full bg-zinc-950 border border-zinc-900 flex items-center justify-center text-slate-600 mb-4">
                <i class="fa-solid fa-magnifying-glass text-lg"></i>
            </div>
            <p class="text-white font-bold">No encontramos prendas para tu búsqueda</p>
            <p class="text-sm text-slate-500 mt-1">Intenta con otra palabra o quita el filtro de categoría.</p>
        </div>
    </section>

    <!-- MODAL DE COMPRA DIRECTA (INTERACTIVO) -->
    <div id="compraModal" class="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden flex items-center justify-center p-4">
        <div class="bg-zinc-950 border border-zinc-900 rounded-2xl w-full max-w-md p-6 relative shadow-2xl modal-transition scale-95 opacity-0" id="modalContainer">
            <!-- Botón Cerrar -->
            <button onclick="cerrarModal()" class="icon-touch absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full text-slate-400 hover:text-white hover:bg-zinc-900 text-sm">
                <i class="fa-solid fa-xmark"></i>
            </button>

            <h3 class="text-xl font-bold text-white mb-1 uppercase tracking-tight" id="modalTitulo">Configurar Pedido</h3>
            <p class="text-xs text-slate-400 mb-6">Selecciona los atributos para generar tu enlace de WhatsApp directo.</p>

            <!-- Formulario del Modal -->
            <div class="space-y-4">
                <!-- Tallas -->
                <div>
                    <label class="text-xs font-bold text-cyan-400 uppercase tracking-widest block mb-2">Selecciona la Talla:</label>
                    <div class="flex flex-wrap gap-2" id="tallaContainer"></div>
                </div>

                <!-- Colores -->
                <div>
                    <label class="text-xs font-bold text-cyan-400 uppercase tracking-widest block mb-2">Selecciona el Color:</label>
                    <div class="flex flex-wrap gap-2" id="colorContainer"></div>
                </div>

                <!-- Precio -->
                <div class="bg-black p-4 rounded-xl border border-zinc-900 flex justify-between items-center mt-6">
                    <span class="text-xs text-slate-500 uppercase font-bold">Total estimado:</span>
                    <span class="text-2xl font-black text-white" id="modalPrecio">$0.00</span>
                </div>

                <!-- Botón de Envío -->
                <button onclick="enviarWhatsApp()" class="icon-touch w-full bg-emerald-500 hover:bg-emerald-400 text-gray-950 font-black py-4 rounded-xl text-sm uppercase tracking-wider transition flex items-center justify-center gap-2 mt-4 shadow-md shadow-emerald-500/10">
                    <i class="fa-brands fa-whatsapp text-base"></i> Confirmar pedido por WhatsApp
                </button>
            </div>
        </div>
    </div>

    <!-- SECCIÓN DE CONTACTO Y UBICACIÓN -->
    <section id="contacto" class="py-16 bg-black border-t border-zinc-900 w-full">
        <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
            <div class="space-y-6">
                <h2 class="text-3xl font-black text-white uppercase tracking-tight">Visítanos en Tienda</h2>
                <p class="text-slate-400">
                    Estamos ubicados en una de las mejores zonas comerciales de Barquisimeto. Acércate para probarte la ropa deportiva en persona y recibir asesoría directa de Clary.
                </p>
                <div class="space-y-4">
                    <div class="flex items-start gap-4">
                        <div class="icon-touch w-9 h-9 rounded-lg bg-zinc-950 border border-zinc-900 flex items-center justify-center text-cyan-400 shrink-0 text-sm">
                            <i class="fa-solid fa-location-dot"></i>
                        </div>
                        <div>
                            <p class="font-bold text-white text-sm">Dirección física</p>
                            <p class="text-sm text-slate-400">Calle 28 entre Carreras 19 y 20, C.C. Cosmos (Antiguo Beco), Local 121-122. Barquisimeto, Lara.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="icon-touch w-9 h-9 rounded-lg bg-zinc-950 border border-zinc-900 flex items-center justify-center text-cyan-400 shrink-0 text-sm">
                            <i class="fa-solid fa-clock"></i>
                        </div>
                        <div>
                            <p class="font-bold text-white text-sm">Horario de Atención</p>
                            <p class="text-sm text-slate-400">Lunes a Sábado: 8:00 AM - 5:30 PM</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mapa simulado interactivo -->
            <div class="h-64 md:h-80 bg-zinc-950 rounded-2xl border border-zinc-900 flex flex-col items-center justify-center text-center p-8 relative overflow-hidden">
                <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#38bdf8_1px,transparent_1px)] [background-size:16px_16px]"></div>
                <div class="relative space-y-4">
                    <div class="w-14 h-14 bg-cyan-950 text-cyan-400 rounded-full flex items-center justify-center text-2xl mx-auto border border-cyan-800/30">
                        <i class="fa-solid fa-map-location-dot"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white">Barquisimeto, Lara</h3>
                    <p class="text-xs text-slate-400 max-w-xs mx-auto">Próximamente integraremos un mapa satelital interactivo para guiarte paso a paso hasta el local de Clary.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- BOTÓN FLOTANTE DE WHATSAPP (discreto, con leve pulso) -->
    <a href="https://wa.me/584245788733" target="_blank"
       class="icon-touch fixed bottom-6 right-6 z-40 w-12 h-12 rounded-full bg-emerald-500 hover:bg-emerald-400 text-gray-950 flex items-center justify-center shadow-lg shadow-emerald-500/20 text-lg">
        <i class="fa-brands fa-whatsapp"></i>
    </a>

    <!-- FOOTER -->
    <footer class="bg-black py-10 border-t border-zinc-900 w-full text-center">
        <div class="max-w-7xl mx-auto px-6 space-y-4">
            <p class="text-xs tracking-wider uppercase font-semibold text-slate-500">
                © 2026 VALERA SPORT. TODOS LOS DERECHOS RESERVADOS.
            </p>
            <p class="text-xs text-slate-600">
                Sitio Web diseñado e integrado por <span class="text-cyan-500/80 font-bold">Gregorio Yepez</span> 
            </p>
        </div>
    </footer>

    <!-- LÓGICA DE PROGRAMACIÓN INTERACTIVA -->
    <script>
        // CODIGO PROTEGIDO - VALERA SPORT (PROPIEDAD PRIVADA)
        eval(decodeURIComponent(escape(atob(""))));
</script>

</body>
</html>